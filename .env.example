# ─── Database (Neon PostgreSQL) ───────────────────────────────────
# Pooled connection (for Prisma Client + Neon adapter WebSocket)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/lakeviewvilla?sslmode=require&pgbouncer=true"
# Direct connection host for CLI: `prisma migrate deploy` reads prisma.config.ts and prefers this URL.
# Use the Neon connection string whose host does NOT contain `-pooler` if migrate hits P1001 on the pooler.
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/lakeviewvilla?sslmode=require"

# ─── NextAuth v5 / Auth.js ────────────────────────────────────────
# Must match how you open the app (e.g. http://127.0.0.1:3000 vs http://localhost:3000).
# Prefer a single secret: set AUTH_SECRET only, OR keep AUTH_SECRET and NEXTAUTH_SECRET identical.
# If both differ (legacy), the app tries both when decrypting session cookies.
# Optional during rotation: AUTH_SECRET_PREVIOUS="<old-value>" so existing cookies still work briefly.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Allow session routes when host != AUTH_URL (fixes UntrustedHost on local / preview). Set "false" for strict checks.
AUTH_TRUST_HOST=true

# ─── Cloudinary (Media Management) ───────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="dbme0nn1m"
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── AI Blog Generation (OpenRouter) ─────────────────────────────
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="google/gemini-2.5-flash-001"

# ─── Hero WebGL ───────────────────────────────────────────────────
# R3F hero is default. Set to 1 to use legacy HeroCanvas instead.
# NEXT_PUBLIC_HERO_LEGACY=1

# ─── Site ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://lakeviewvillatangalle.com"
NEXT_PUBLIC_WHATSAPP="+94701164056"

# ─── Analytics ────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=""

# ─── Playwright E2E (optional) ─────────────────────────────────────
# MANAGER or DEVELOPER user — publish action requires elevated role.
# PLAYWRIGHT_BASE_URL="http://127.0.0.1:3000"
# PLAYWRIGHT_ADMIN_EMAIL=""
# PLAYWRIGHT_ADMIN_PASSWORD=""
# PLAYWRIGHT_SKIP_WEBSERVER=1   # when you already run `pnpm dev` manually
